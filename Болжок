<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#0f0c29; font-family:'Segoe UI',sans-serif; display:flex; justify-content:center; }
input[type=number]::-webkit-inner-spin-button { -webkit-appearance:none; }
input,select { -webkit-appearance:none; }
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useMemo } = React;

const DEFAULT_CATS = {
income: [
{id:“salary”,label:“Цалин”,emoji:“💼”},
{id:“freelance”,label:“Freelance”,emoji:“💻”},
{id:“rent_in”,label:“Түрээс”,emoji:“🏠”},
{id:“other_in”,label:“Бусад”,emoji:“➕”},
],
expense: [
{id:“food”,label:“Хоол”,emoji:“🍜”},
{id:“transport”,label:“Тээвэр”,emoji:“🚌”},
{id:“rent”,label:“Түрээс”,emoji:“🏠”},
{id:“entertainment”,label:“Цэнгэл”,emoji:“🎉”},
{id:“health”,label:“Эрүүл мэнд”,emoji:“💊”},
{id:“shopping”,label:“Дэлгүүр”,emoji:“🛍️”},
{id:“other_ex”,label:“Бусад”,emoji:“📦”},
],
};

const EMOJIS=[“💼”,“💻”,“🏠”,“➕”,“🍜”,“🚌”,“🎉”,“💊”,“🛍️”,“📦”,“🎓”,“✈️”,“🐶”,“💅”,“🏋️”,“🎮”,“🍕”,“☕”,“🚗”,“🎁”,“📱”,“🏦”,“💰”,“🌿”,“🎵”,“📚”,“🧴”,“👗”,“🍺”,“⚽”];
const MONTHS=[“1-р сар”,“2-р сар”,“3-р сар”,“4-р сар”,“5-р сар”,“6-р сар”,“7-р сар”,“8-р сар”,“9-р сар”,“10-р сар”,“11-р сар”,“12-р сар”];
const TABS=[“Нүүр”,“Бүртгэл”,“Хадгаламж”,“Тайлан”,“Тохиргоо”];
const TAB_ICONS=[“🏠”,“✏️”,“💰”,“📊”,“⚙️”];

function fmt(n){return (n||0).toLocaleString()+“₮”;}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2);}

function App(){
const [tab,setTab]=useState(0);
const [transactions,setTransactions]=useState(()=>{try{return JSON.parse(localStorage.getItem(“tsgt_tx”)||”[]”);}catch{return [];}});
const [savings,setSavings]=useState(()=>{try{return parseInt(localStorage.getItem(“tsgt_sav”)||“0”);}catch{return 0;}});
const [cats,setCats]=useState(()=>{try{return JSON.parse(localStorage.getItem(“tsgt_cats”)||“null”)||DEFAULT_CATS;}catch{return DEFAULT_CATS;}});
const [monthlyIncome,setMonthlyIncome]=useState(()=>{try{return parseInt(localStorage.getItem(“tsgt_mi”)||“5000000”);}catch{return 5000000;}});
const [form,setForm]=useState({type:“expense”,category:“food”,amount:””,note:””,date:new Date().toISOString().split(“T”)[0]});
const [savingInput,setSavingInput]=useState(””);
const [added,setAdded]=useState(false);
const [editTx,setEditTx]=useState(null);
const [catTab,setCatTab]=useState(“expense”);
const [newCat,setNewCat]=useState({label:””,emoji:“🎁”});
const [showAddCat,setShowAddCat]=useState(false);
const [showEmojiPicker,setShowEmojiPicker]=useState(false);
const [miInput,setMiInput]=useState(””);
const [reportMonth,setReportMonth]=useState(()=>{const n=new Date();return `${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,"0")}`;});

useEffect(()=>{localStorage.setItem(“tsgt_tx”,JSON.stringify(transactions));},[transactions]);
useEffect(()=>{localStorage.setItem(“tsgt_sav”,savings.toString());},[savings]);
useEffect(()=>{localStorage.setItem(“tsgt_cats”,JSON.stringify(cats));},[cats]);
useEffect(()=>{localStorage.setItem(“tsgt_mi”,monthlyIncome.toString());},[monthlyIncome]);

const totalIncome=transactions.filter(t=>t.type===“income”).reduce((s,t)=>s+t.amount,0);
const totalExpense=transactions.filter(t=>t.type===“expense”).reduce((s,t)=>s+t.amount,0);
const balance=totalIncome-totalExpense;
const savingPercent=Math.min((savings/12000000)*100,100);
const budgetUsed=(totalExpense/(monthlyIncome*0.5))*100;

// Report month data
const reportTx=useMemo(()=>transactions.filter(t=>t.date&&t.date.startsWith(reportMonth)),[transactions,reportMonth]);
const rIncome=reportTx.filter(t=>t.type===“income”).reduce((s,t)=>s+t.amount,0);
const rExpense=reportTx.filter(t=>t.type===“expense”).reduce((s,t)=>s+t.amount,0);
const rBalance=rIncome-rExpense;
const rExpByCat=cats.expense.map(c=>({…c,total:reportTx.filter(t=>t.type===“expense”&&t.category===c.id).reduce((s,t)=>s+t.amount,0)})).filter(c=>c.total>0).sort((a,b)=>b.total-a.total);

// Available months from transactions
const availableMonths=useMemo(()=>{
const set=new Set(transactions.map(t=>t.date?t.date.slice(0,7):””).filter(Boolean));
const n=new Date();
set.add(`${n.getFullYear()}-${String(n.getMonth()+1).padStart(2,"0")}`);
return Array.from(set).sort().reverse();
},[transactions]);

// Smart advice
const advice=useMemo(()=>{
const tips=[];
const savingRate=totalIncome>0?savings/totalIncome:0;
const expenseRate=totalIncome>0?totalExpense/totalIncome:0;
if(totalIncome===0)return [{icon:“💡”,text:“Орлогоо бүртгэж эхэлнэ үү.”,color:”#a89fd8”}];
if(expenseRate>0.8) tips.push({icon:“🚨”,text:`Орлогынхоо ${Math.round(expenseRate*100)}%-ийг зарцуулж байна. Хэмнэлт хийх шаардлагатай!`,color:”#ff6b6b”});
else if(expenseRate>0.5) tips.push({icon:“⚠️”,text:`Зарлага орлогын ${Math.round(expenseRate*100)}%-д хүрлээ. Анхаарна уу.`,color:”#ffd200”});
else tips.push({icon:“✅”,text:`Зарлагын харьцаа сайн байна (${Math.round(expenseRate*100)}%). Үргэлжлүүлнэ үү!`,color:”#7ee8a2”});
if(savings<monthlyIncome*0.2) tips.push({icon:“💰”,text:`Нэг сарын хадгаламжийн зорилт: ${fmt(monthlyIncome*0.2)}. Одоо ${fmt(savings)} байна.`,color:”#ffd700”});
else tips.push({icon:“🏆”,text:“Хадгаламжийн зорилтоо биелүүлж байна! Гайхалтай.”,color:”#7ee8a2”});
const topCat=rExpByCat[0];
if(topCat&&topCat.total>monthlyIncome*0.3) tips.push({icon:“📌”,text:`"${topCat.label}" зарлага их байна (${fmt(topCat.total)}). Дэлгэрэнгүй харна уу.`,color:”#a855f7”});
if(rBalance<0) tips.push({icon:“❌”,text:`Энэ сар ${fmt(Math.abs(rBalance))}-ийн алдагдалтай байна. Зарлагаа бууруулна уу.`,color:”#ff6b6b”});
else if(rBalance>0) tips.push({icon:“💚”,text:`Энэ сар ${fmt(rBalance)} үлдэгдэлтэй байна. Хадгаламждаа нэмэрлэх боломжтой.`,color:”#7ee8a2”});
if(transactions.length>0){
const lastDate=new Date(Math.max(…transactions.map(t=>new Date(t.date))));
const daysSince=Math.floor((new Date()-lastDate)/86400000);
if(daysSince>3) tips.push({icon:“📝”,text:`${daysSince} өдөр гүйлгээ бүртгээгүй байна. Тогтмол бүртгэнэ үү!`,color:”#f7971e”});
}
return tips;
},[transactions,savings,monthlyIncome,rBalance,rExpByCat,reportMonth]);

function addTransaction(){
if(!form.amount||isNaN(form.amount))return;
if(editTx){
setTransactions(prev=>prev.map(t=>t.id===editTx?{…form,id:editTx,amount:parseInt(form.amount)}:t));
setEditTx(null);
} else {
setTransactions(prev=>[{…form,id:uid(),amount:parseInt(form.amount)},…prev]);
}
setForm({type:“expense”,category:“food”,amount:””,note:””,date:new Date().toISOString().split(“T”)[0]});
setAdded(true); setTimeout(()=>setAdded(false),1800);
}

function deleteTx(id){setTransactions(prev=>prev.filter(t=>t.id!==id));}
function startEdit(t){setForm({type:t.type,category:t.category,amount:t.amount.toString(),note:t.note,date:t.date});setEditTx(t.id);setTab(1);}
function addSaving(){const a=parseInt(savingInput);if(!a||isNaN(a))return;setSavings(p=>p+a);setSavingInput(””);}
function withdrawSaving(){const a=parseInt(savingInput);if(!a||isNaN(a))return;setSavings(p=>Math.max(0,p-a));setSavingInput(””);}
function getCatLabel(type,id){const f=(cats[type]||[]).find(c=>c.id===id);return f?`${f.emoji} ${f.label}`:id;}
function addCat(){if(!newCat.label.trim())return;setCategories?null:setCats(p=>({…p,[catTab]:[…p[catTab],{id:uid(),label:newCat.label.trim(),emoji:newCat.emoji}]}));setNewCat({label:””,emoji:“🎁”});setShowAddCat(false);}
function delCat(type,id){setCats(p=>({…p,[type]:p[type].filter(c=>c.id!==id)}));}

const inp={width:“100%”,background:“rgba(0,0,0,0.3)”,border:“1px solid rgba(255,255,255,0.15)”,borderRadius:12,padding:“12px 14px”,color:”#fff”,fontSize:15,outline:“none”,boxSizing:“border-box”};
const card={background:“rgba(255,255,255,0.07)”,borderRadius:18,padding:18,marginBottom:16};
const bar=(pct,color)=>({height:“100%”,borderRadius:99,width:`${Math.min(pct,100)}%`,background:color,transition:“width 0.6s”});

return (
<div style={{minHeight:“100vh”,background:“linear-gradient(135deg,#0f0c29 0%,#302b63 50%,#24243e 100%)”,color:”#fff”,display:“flex”,flexDirection:“column”,maxWidth:480,margin:“0 auto”}}>

```
  {/* Header */}
  <div style={{padding:"28px 24px 8px"}}>
