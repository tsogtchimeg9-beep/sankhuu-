          <div style={bar(budgetUsed,budgetUsed>90?"linear-gradient(90deg,#ff6b6b,#ee0979)":budgetUsed>60?"linear-gradient(90deg,#f7971e,#ffd200)":"linear-gradient(90deg,#7ee8a2,#00b09b)")}/>
