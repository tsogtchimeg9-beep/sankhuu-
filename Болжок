    <div style={{fontSize:30,fontWeight:800}}>{fmt(balance)}</div>
    <div style={{fontSize:13,color:balance>=0?"#7ee8a2":"#ff6b6b",marginTop:2}}>{balance>=0?"✅ Тэнцвэртэй":"⚠️ Зарлага илүүдсэн"}</div>
    <div style={{display:"flex",gap:12,marginTop:18}}>
