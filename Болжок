      </div>
      <div style={card}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12,color:"#a89fd8"}}>📌 50/30/20 Зөвлөмж</div>
        {[
          {label:"🏠 Зайлшгүй зардал",pct:50,color:"#4facfe"},
          {label:"🎉 Хүслийн зардал",pct:30,color:"#a855f7"},
          {label:"💰 Хадгаламж",pct:20,color:"#ffd700"},
        ].map(item=>(
          <div key={item.label} style={{marginBottom:12}}>
            <div style={{display:"flex",justifyContent:"space-between",fontSize:12,marginBottom:4}}>
              <span>{item.label}</span>
              <span style={{color:item.color,fontWeight:700}}>{fmt(monthlyIncome*item.pct/100)}</span>
            </div>
            <div style={{background:"rgba(255,255,255,0.1)",borderRadius:99,height:6}}>
              <div style={{height:"100%",borderRadius:99,width:`${item.pct}%`,background:item.color}}/>
            </div>
          </div>
        ))}
      </div>
    </div>}

    {/* REPORT */}
    {tab===3&&<div>
      {/* Month selector */}
      <div style={card}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12}}>📅 Сар сонгох</div>
        <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
          {availableMonths.map(m=>{
            const [y,mo]=m.split("-");
            return(
              <button key={m} onClick={()=>setReportMonth(m)}
                style={{border:"none",borderRadius:10,padding:"7px 14px",cursor:"pointer",fontSize:12,fontWeight:600,background:reportMonth===m?"#7c3aed":"rgba(255,255,255,0.1)",color:"#fff"}}>
                {y}он {MONTHS[parseInt(mo)-1]}
              </button>
            );
          })}
        </div>
      </div>

      {/* Month summary */}
      <div style={{...card,background:"linear-gradient(135deg,rgba(124,58,237,0.2),rgba(168,85,247,0.1))",border:"1px solid rgba(124,58,237,0.3)"}}>
        <div style={{fontSize:14,fontWeight:700,marginBottom:14}}>
          {reportMonth.split("-")[0]}он {MONTHS[parseInt(reportMonth.split("-")[1])-1]} тайлан
        </div>
        <div style={{display:"flex",gap:12,marginBottom:12}}>
          <div style={{flex:1,background:"rgba(126,232,162,0.12)",borderRadius:14,padding:"12px"}}>
            <div style={{fontSize:11,color:"#7ee8a2",marginBottom:4}}>Орлого</div>
            <div style={{fontWeight:800,fontSize:16,color:"#7ee8a2"}}>+{fmt(rIncome)}</div>
          </div>
          <div style={{flex:1,background:"rgba(255,107,107,0.12)",borderRadius:14,padding:"12px"}}>
            <div style={{fontSize:11,color:"#ff9a9a",marginBottom:4}}>Зарлага</div>
            <div style={{fontWeight:800,fontSize:16,color:"#ff9a9a"}}>-{fmt(rExpense)}</div>
          </div>
        </div>
        <div style={{background:"rgba(255,255,255,0.08)",borderRadius:14,padding:"12px",textAlign:"center"}}>
          <div style={{fontSize:11,color:"#a89fd8",marginBottom:4}}>Үлдэгдэл</div>
          <div style={{fontWeight:900,fontSize:22,color:rBalance>=0?"#ffd700":"#ff6b6b"}}>{rBalance>=0?"+":""}{fmt(rBalance)}</div>
        </div>
      </div>

      {/* Expense breakdown */}
      {rExpByCat.length>0&&<div style={card}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:14}}>📊 Зарлагын задаргаа</div>
        {rExpByCat.map(c=>{
          const pct=rExpense>0?(c.total/rExpense)*100:0;
          return(
            <div key={c.id} style={{marginBottom:14}}>
              <div style={{display:"flex",justifyContent:"space-between",fontSize:13,marginBottom:5}}>
                <span>{c.emoji} {c.label}</span>
                <span style={{fontWeight:700}}>{fmt(c.total)} <span style={{color:"#a89fd8",fontWeight:400}}>({Math.round(pct)}%)</span></span>
              </div>
              <div style={{background:"rgba(255,255,255,0.1)",borderRadius:99,height:8}}>
                <div style={{height:"100%",borderRadius:99,width:`${pct}%`,background:"linear-gradient(90deg,#a855f7,#7c3aed)"}}/>
              </div>
            </div>
          );
        })}
      </div>}

      {/* Transactions of month */}
      <div style={{fontSize:13,fontWeight:700,color:"#a89fd8",marginBottom:10}}>Гүйлгээнүүд ({reportTx.length})</div>
      {reportTx.length===0&&<div style={{color:"#a89fd8",fontSize:13,textAlign:"center",padding:"20px 0"}}>Энэ сард гүйлгээ байхгүй</div>}
      {reportTx.map(t=>(
        <div key={t.id} style={{display:"flex",alignItems:"center",background:"rgba(255,255,255,0.05)",borderRadius:14,padding:"12px 14px",marginBottom:8}}>
          <div style={{flex:1}}>
            <div style={{fontSize:13,fontWeight:600}}>{getCatLabel(t.type,t.category)}</div>
            <div style={{fontSize:11,color:"#a89fd8"}}>{t.note} · {t.date}</div>
          </div>
          <div style={{fontWeight:700,color:t.type==="income"?"#7ee8a2":"#ff9a9a",fontSize:14}}>{t.type==="income"?"+":"-"}{fmt(t.amount)}</div>
        </div>
      ))}
    </div>}

    {/* SETTINGS */}
    {tab===4&&<div>
      {/* Monthly income */}
      <div style={card}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12}}>💼 Сарын орлого тохируулах</div>
        <div style={{fontSize:12,color:"#a89fd8",marginBottom:8}}>Одоогийн: {fmt(monthlyIncome)}</div>
        <div style={{display:"flex",gap:10}}>
          <input type="number" value={miInput} onChange={e=>setMiInput(e.target.value)} placeholder="Шинэ дүн..." style={{...inp,flex:1}}/>
          <button onClick={()=>{const a=parseInt(miInput);if(a&&!isNaN(a)){setMonthlyIncome(a);setMiInput("");}}} style={{border:"none",borderRadius:12,padding:"0 16px",cursor:"pointer",background:"linear-gradient(90deg,#7c3aed,#a855f7)",color:"#fff",fontWeight:800,fontSize:13}}>Хадгалах</button>
        </div>
      </div>

      {/* Category management */}
      <div style={card}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12}}>🗂️ Ангилал удирдах</div>
        <div style={{display:"flex",background:"rgba(0,0,0,0.3)",borderRadius:12,padding:4,marginBottom:16}}>
          {["expense","income"].map(type=>(
            <button key={type} onClick={()=>setCatTab(type)}
              style={{flex:1,border:"none",borderRadius:9,padding:"8px 0",cursor:"pointer",fontSize:13,fontWeight:600,background:catTab===type?(type==="income"?"#7ee8a2":"#ff6b6b"):"transparent",color:catTab===type?"#111":"#888"}}>
              {type==="income"?"📈 Орлого":"📉 Зарлага"}
            </button>
          ))}
        </div>
        {cats[catTab].map(c=>(
          <div key={c.id} style={{display:"flex",alignItems:"center",background:"rgba(255,255,255,0.05)",borderRadius:12,padding:"10px 14px",marginBottom:8}}>
            <span style={{fontSize:18,marginRight:10}}>{c.emoji}</span>
            <span style={{flex:1,fontSize:14}}>{c.label}</span>
            <button onClick={()=>delCat(catTab,c.id)} style={{border:"none",background:"rgba(255,80,80,0.2)",borderRadius:8,padding:"4px 8px",cursor:"pointer",fontSize:12,color:"#ff9a9a"}}>Хасах</button>
          </div>
        ))}
        {!showAddCat&&<button onClick={()=>setShowAddCat(true)} style={{width:"100%",border:"none",borderRadius:12,padding:"11px 0",cursor:"pointer",background:"rgba(124,58,237,0.3)",color:"#a855f7",fontWeight:700,fontSize:13,marginTop:8}}>➕ Шинэ ангилал нэмэх</button>}
        {showAddCat&&<div style={{background:"rgba(0,0,0,0.3)",borderRadius:14,padding:14,marginTop:8}}>
          <div style={{fontSize:12,color:"#a89fd8",marginBottom:8}}>Emoji сонгох</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:6,marginBottom:12}}>
            {EMOJIS.map(e=>(
              <button key={e} onClick={()=>setNewCat(n=>({...n,emoji:e}))}
                style={{border:newCat.emoji===e?"2px solid #a855f7":"2px solid transparent",borderRadius:8,padding:"4px 6px",cursor:"pointer",background:"rgba(255,255,255,0.1)",fontSize:18}}>
                {e}
              </button>
            ))}
          </div>
          <input type="text" value={newCat.label} onChange={e=>setNewCat(n=>({...n,label:e.target.value}))} placeholder="Ангилалын нэр..." style={{...inp,marginBottom:10}}/>
          <div style={{display:"flex",gap:8}}>
            <button onClick={()=>{if(!newCat.label.trim())return;setCats(p=>({...p,[catTab]:[...p[catTab],{id:uid(),label:newCat.label.trim(),emoji:newCat.emoji}]}));setNewCat({label:"",emoji:"🎁"});setShowAddCat(false);}} style={{flex:1,border:"none",borderRadius:10,padding:"10px 0",cursor:"pointer",background:"linear-gradient(90deg,#7c3aed,#a855f7)",color:"#fff",fontWeight:700}}>Нэмэх</button>
            <button onClick={()=>setShowAddCat(false)} style={{flex:1,border:"none",borderRadius:10,padding:"10px 0",cursor:"pointer",background:"rgba(255,255,255,0.1)",color:"#fff",fontWeight:700}}>Болих</button>
          </div>
        </div>}
      </div>

      {/* Danger zone */}
      <div style={{...card,border:"1px solid rgba(255,80,80,0.3)"}}>
        <div style={{fontSize:13,fontWeight:700,marginBottom:12,color:"#ff9a9a"}}>⚠️ Өгөгдөл устгах</div>
        <button onClick={()=>{if(window.confirm("Бүх гүйлгээг устгах уу?")){setTransactions([]);}}} style={{width:"100%",border:"none",borderRadius:12,padding:"11px 0",cursor:"pointer",background:"rgba(255,80,80,0.2)",color:"#ff9a9a",fontWeight:700,fontSize:13,marginBottom:8}}>🗑️ Бүх гүйлгээ устгах</button>
        <button onClick={()=>{if(window.confirm("Хадгаламжийг тэглэх үү?")){setSavings(0);}}} style={{width:"100%",border:"none",borderRadius:12,padding:"11px 0",cursor:"pointer",background:"rgba(255,80,80,0.2)",color:"#ff9a9a",fontWeight:700,fontSize:13}}>🗑️ Хадгаламж тэглэх</button>
      </div>
    </div>}
  </div>

  {/* Bottom nav */}
  <div style={{position:"fixed",bottom:0,left:"50%",transform:"translateX(-50%)",width:"100%",maxWidth:480,background:"rgba(15,12,41,0.97)",borderTop:"1px solid rgba(255,255,255,0.1)",display:"flex",padding:"10px 0 18px"}}>
    {TABS.map((t,i)=>(
      <button key={t} onClick={()=>setTab(i)} style={{flex:1,border:"none",background:"transparent",cursor:"pointer",display:"flex",flexDirection:"column",alignItems:"center",gap:3,color:tab===i?"#a855f7":"#555"}}>
        <span style={{fontSize:20}}>{TAB_ICONS[i]}</span>
        <span style={{fontSize:9,fontWeight:tab===i?700:400}}>{t}</span>
      </button>
    ))}
  </div>
</div>
